{
  "name": "@zootopia/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "next dev --turbopack",
    "build": "npm run build:local",
    "build:local": "node --max-old-space-size=16384 -e \"const{spawnSync}=require('node:child_process');const nextBin=require.resolve('next/dist/bin/next');const result=spawnSync(process.execPath,[nextBin,'build'],{stdio:'inherit'});process.exit(result.status??1);\"",
    "postbuild": "node ./scripts/normalize-standalone.mjs",
    "build:vercel": "next build",
    "start": "npm run start:local",
    "start:local": "next start",
    "start:vercel": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@sparticuz/chromium": "^143.0.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "framer-motion": "12.38.0",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^8.0.4",
    "postgres": "^3.4.5",
    "puppeteer-core": "^24.35.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-phone-number-input": "^3.4.16",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@zootopia/shared-config": "file:../../packages/shared-config",
    "@zootopia/shared-types": "file:../../packages/shared-types",
    "@zootopia/shared-utils": "file:../../packages/shared-utils",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
