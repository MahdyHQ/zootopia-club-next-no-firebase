# Environment template for local development.
# Copy to .env.local and fill required values. Never commit real secrets.

# Public browser auth config (required).
# Used by apps/web/lib/supabase/client.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional browser auth alias kept for compatibility with Supabase key naming.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server auth config (required for /api/auth/* runtime).
# SUPABASE_URL can reuse NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Postgres connection string (Supabase Dashboard → Connect → Transaction pooler or direct).
# Required with SUPABASE_SERVICE_ROLE_KEY for durable app data (replaces former Firestore).
SUPABASE_DATABASE_URL=

# Optional alias some tools use for Postgres URLs.
# DATABASE_URL=

# Admin allowlist used by server auth guards.
ZOOTOPIA_ADMIN_EMAILS=alahlyeagle@gmail.com,elmahdy@admin.com,alahlyeagle13@gmail.com

# Session and assessment credit controls.
ZOOTOPIA_SESSION_TTL_SECONDS=3600
ZOOTOPIA_DEFAULT_DAILY_ASSESSMENT_CREDITS=3

# Optional maintenance endpoint secret.
ZOOTOPIA_MAINTENANCE_SECRET=

# AI provider runtime secrets (at least one provider key is required for generation).
GOOGLE_AI_API_KEY=
DASHSCOPE_API_KEY=

# Optional AI runtime tuning.
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_COMPATIBLE_BASE_URL=
ALIBABA_MODEL_STUDIO_BASE_URL=
GOOGLE_AI_MODEL=
GOOGLE_AI_ADVANCED_MODEL=
QWEN_MODEL=

# Contact relay runtime (required only when /api/contact is enabled).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
CONTACT_FORM_TO=

# Local Pro PDF executable overrides (optional).
ASSESSMENT_PDF_BROWSER_EXECUTABLE_PATH=
PUPPETEER_EXECUTABLE_PATH=
