# Environment template for local development.
# Copy to .env.local and fill required values. Never commit real secrets.
# This template targets the repo-root .env.local used by local Next runtime and root scripts.

# Auth.js session crypto secret (required).
# Generate with: npx auth secret
AUTH_SECRET=

# Canonical app origin used by server-side internal fetches and auth callback link construction.
# Set this in production (custom domain or Vercel domain) to keep origin handling deterministic.
# Examples:
#   NEXT_PUBLIC_BASE_URL=https://zootopia-club.com
#   NEXT_PUBLIC_BASE_URL=https://<vercel-deployment>.vercel.app
NEXT_PUBLIC_BASE_URL=

# Optional explicit Auth.js base URL fallback used when NEXT_PUBLIC_BASE_URL is not set.
# NEXTAUTH_URL=

# Public browser auth config (required).
# Used by apps/web/lib/supabase/client.ts.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional browser auth alias kept for compatibility with Supabase key naming.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server auth config (required for /api/auth/* runtime).
# SUPABASE_URL can reuse NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Postgres connection string (Supabase Dashboard -> Connect -> Transaction pooler).
# Use the pooler URI for IPv4-friendly resolution; direct db.<project-ref>.supabase.co can fail on IPv4-only hosts.
# Required with SUPABASE_SERVICE_ROLE_KEY for durable app data (replaces former Firestore).
SUPABASE_DATABASE_URL=

# Optional alias some tools use for Postgres URLs.
# DATABASE_URL=

# Legacy Firebase script compatibility (commented by default).
# These are not used by the current Supabase app runtime, but retained scripts still read them
# from the repo-root .env.local during migration fallback and historical QA workflows.
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# Admin allowlist used by server auth guards.
ZOOTOPIA_ADMIN_EMAILS=alahlyeagle@gmail.com,elmahdy@admin.com,alahlyeagle13@gmail.com

# Optional: Legacy admin login password gate (deprecated, no longer required).
# This variable is kept for backward compatibility but is no longer enforced by the admin auth flow.
# Admin authentication is now protected by: allowlist + Supabase claims + request recency checks.
# ZOOTOPIA_ADMIN_LOGIN_PASSWORD=

# Session and assessment credit controls.
ZOOTOPIA_SESSION_TTL_SECONDS=3600
ZOOTOPIA_DEFAULT_DAILY_ASSESSMENT_CREDITS=3

# Auth redirect defaults after successful login/bootstrap and confirm-email finalization.
# Keep these values as internal relative paths only (for example "/", "/upload", "/admin").
# Using NEXT_PUBLIC keys keeps server and client redirect decisions aligned in Next App Router.
NEXT_PUBLIC_ZOOTOPIA_AUTH_USER_DEFAULT_REDIRECT=/
NEXT_PUBLIC_ZOOTOPIA_AUTH_ADMIN_DEFAULT_REDIRECT=/

# Email verification resend governance (server-authoritative).
# Canonical keys use the ZOOTOPIA_EMAIL_VERIFICATION_* prefix.
# Defaults if unset:
# - cooldown: 30 seconds
# - account max attempts: 5
# - account window: 60 minutes
# - IP max attempts: 20
# - IP window: 60 minutes
ZOOTOPIA_EMAIL_VERIFICATION_RESEND_MODE=provider
ZOOTOPIA_EMAIL_VERIFICATION_COOLDOWN_SECONDS=30
ZOOTOPIA_EMAIL_VERIFICATION_MAX_ATTEMPTS=5
ZOOTOPIA_EMAIL_VERIFICATION_WINDOW_MINUTES=60
ZOOTOPIA_EMAIL_VERIFICATION_IP_MAX_ATTEMPTS=20
ZOOTOPIA_EMAIL_VERIFICATION_IP_WINDOW_MINUTES=60
ZOOTOPIA_EMAIL_VERIFICATION_HASH_SALT=

# Legacy resend-governance aliases are still accepted for compatibility.
# ZOOTOPIA_VERIFICATION_RESEND_MODE=provider
# ZOOTOPIA_VERIFICATION_RESEND_COOLDOWN_SECONDS=30
# ZOOTOPIA_VERIFICATION_RESEND_ACCOUNT_MAX_ATTEMPTS=5
# ZOOTOPIA_VERIFICATION_RESEND_ACCOUNT_WINDOW_SECONDS=3600
# ZOOTOPIA_VERIFICATION_RESEND_IP_MAX_ATTEMPTS=20
# ZOOTOPIA_VERIFICATION_RESEND_IP_WINDOW_SECONDS=3600
# ZOOTOPIA_VERIFICATION_RESEND_HASH_SALT=

# Storage retention policy (per storage type).
# Defaults if unset:
# - uploads/documents: 15 minutes
# - generated results: 1440 minutes (1 day)
# - exports: 15 minutes
# Set mode to "none" for a scope only when you intentionally want no automatic expiry.
ZOOTOPIA_UPLOAD_RETENTION_MINUTES=15
ZOOTOPIA_RESULT_RETENTION_MINUTES=1440
ZOOTOPIA_EXPORT_RETENTION_MINUTES=15
ZOOTOPIA_UPLOAD_RETENTION_MODE=expiry
ZOOTOPIA_RESULT_RETENTION_MODE=expiry
ZOOTOPIA_EXPORT_RETENTION_MODE=expiry

# Legacy global retention fallback (optional; only used when per-scope values are missing).
# ZOOTOPIA_STORAGE_RETENTION_DAYS=3
# ZOOTOPIA_STORAGE_RETENTION_HOURS=0
# ZOOTOPIA_STORAGE_RETENTION_MODE=expiry

# Optional maintenance endpoint secret.
ZOOTOPIA_MAINTENANCE_SECRET=

# AI provider runtime secrets (at least one provider key is required for generation).
GOOGLE_AI_API_KEY=
DASHSCOPE_API_KEY=

# Optional AI runtime tuning.
# Qwen runtime now requires a DashScope-compatible base URL; use DASHSCOPE_BASE_URL as the canonical key.
# Legacy aliases remain supported for backward compatibility with older scripts/environments.
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
#DASHSCOPE_COMPATIBLE_BASE_URL=
#ALIBABA_MODEL_STUDIO_BASE_URL=
#GOOGLE_AI_MODEL=
#GOOGLE_AI_ADVANCED_MODEL=
#QWEN_MODEL=

# Contact relay runtime (required only when /api/contact is enabled).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
CONTACT_FORM_TO=

# Local Pro PDF executable overrides (optional).
ASSESSMENT_PDF_BROWSER_EXECUTABLE_PATH=
PUPPETEER_EXECUTABLE_PATH=
